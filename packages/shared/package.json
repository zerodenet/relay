{
  "name": "@zero-panel/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Zero Relay Panel — shared zod schemas and types.",
  "author": "zerodenet (https://zerodenet.org)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/zerodenet/relay.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/zerodenet/relay#readme",
  "bugs": {
    "url": "https://github.com/zerodenet/relay/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}

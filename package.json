{
  "name": "zero-relay-panel",
  "version": "0.0.1",
  "private": true,
  "description": "Transparent L7 relay gateway panel built on the Zero proxy kernel.",
  "author": "zerodenet (https://zerodenet.org)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/zerodenet/relay.git"
  },
  "bugs": {
    "url": "https://github.com/zerodenet/relay/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./packages/*\" run dev",
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "start": "pnpm --filter @zero-panel/server start",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/*\" run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  }
}
